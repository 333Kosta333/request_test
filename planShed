## 5. SQL скрипты

### 5.1. Таблица `auto_claim_templates`
sql
CREATE TABLE auto_claim_templates (
    id BIGSERIAL PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    service_type VARCHAR(255),
    template_data JSONB,
    interval_seconds INTEGER DEFAULT 3600,
    last_execution_time TIMESTAMPTZ,
    is_active BOOLEAN DEFAULT TRUE
);

## 5.2 Таблица auto_claim_task_locks
sql
CREATE TABLE auto_claim_task_locks (
    template_id BIGINT PRIMARY KEY REFERENCES auto_claim_templates(id) ON DELETE CASCADE,
    status VARCHAR(50) NOT NULL DEFAULT 'PENDING',
    lock_token VARCHAR(255) NOT NULL UNIQUE,
    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    expires_at TIMESTAMPTZ NOT NULL
);

CREATE INDEX idx_auto_claim_task_locks_status ON auto_claim_task_locks(status);
CREATE INDEX idx_auto_claim_task_locks_expires ON auto_claim_task_locks(expires_at);

## 5.3. Таблица auto_claim_execution_logs
sql
CREATE TABLE auto_claim_execution_logs (
    id BIGSERIAL PRIMARY KEY,
    template_id BIGINT NOT NULL REFERENCES auto_claim_templates(id) ON DELETE CASCADE,
    execution_time TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    status VARCHAR(20) NOT NULL,
    response_payload TEXT,
    error_message TEXT,
    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_auto_claim_execution_logs_template_id ON auto_claim_execution_logs(template_id);
CREATE INDEX idx_auto_claim_execution_logs_status ON auto_claim_execution_logs(status);
CREATE INDEX idx_auto_claim_execution_logs_created_at ON auto_claim_execution_logs(created_at);

## 6. Безопасность и отказоустойчивость
Блокировка реализована через уникальный ключ template_id и ограничение на status = 'PENDING'.
Блокировка автоматически истекает по времени expires_at.
Повторный захват возможен, если статус PENDING или задача просрочена.
Результаты выполнения сохраняются для аудита и отладки.

## 7. Логирование и мониторинг
Все попытки захвата блокировок логируются.
Факты создания заявок логируются.
Ошибки обрабатываются и логируются.
Метрики: количество попыток, успехов, ошибок, просроченных задач.
Хранение всех результатов выполнения задач.

